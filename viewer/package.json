{
  "name": "pkis-viewer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "build:native": "CAP_BUILD=1 vite build",
    "cap:sync": "CAP_BUILD=1 vite build && cap sync android",
    "cap:open": "cap open android",
    "apk": "VITE_API_BASE_URL=https://pkis.dev CAP_BUILD=1 vite build && cap sync android && cd android && ./gradlew assembleDebug",
    "apk:dev": "VITE_API_BASE_URL=http://10.0.2.2:5000 CAP_BUILD=1 vite build && cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.4.11",
    "cytoscape": "^3.29.2",
    "katex": "^0.16.11",
    "marked": "^12.0.0",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.3.3",
    "vite": "^5.3.1",
    "vitest": "^2.1.9"
  }
}
